import React, { useState, useRef, useEffect } from 'react';
import { 
  Camera, MessageSquare, Download, Trash2, 
  UploadCloud, ShieldAlert, Undo2, AlertCircle,
  Eraser, RotateCw, Maximize2, Pencil, Copy, CheckCircle2
} from 'lucide-react';

const App = () => {
  const [image, setImage] = useState(null);
  const [comments, setComments] = useState([]);
  const [activeArea, setActiveArea] = useState(null);
  const [hoveredArea, setHoveredArea] = useState(null); // State cho Hover Highlight
  const [isDrawing, setIsDrawing] = useState(false);
  const [startPos, setStartPos] = useState(null);
  const [currentArea, setCurrentArea] = useState(null);
  const [inputText, setInputText] = useState('');
  const [isExporting, setIsExporting] = useState(false);
  const [isCopied, setIsCopied] = useState(false);
  const [mode, setMode] = useState('comment'); 
  const [isEditing, setIsEditing] = useState(false);
  const [editingId, setEditingId] = useState(null);
  
  const [transformState, setTransformState] = useState({
    type: null, handle: null, areaId: null, startMouse: { x: 0, y: 0 }, initialData: null
  });

  const imageRef = useRef(null);
  const fileInputRef = useRef(null);

  // --- SHORTCUTS & PASTE EVENT LISTENER (ANTIGRAVITY WORKFLOW) ---
  useEffect(() => {
    const handleKeyDown = (e) => {
      // Bỏ qua nếu đang gõ text trong textarea/input
      if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;

      if (e.key === 'Delete' || e.key === 'Backspace') {
        if (activeArea) deleteArea(activeArea);
      }
      if (e.key.toLowerCase() === 'c') setMode('comment');
      if (e.key.toLowerCase() === 'b') setMode('blur');
      if (e.key === 'Escape') setActiveArea(null);
    };

    const handlePaste = (e) => {
      // Bỏ qua nếu đang paste text vào ô input
      if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;
      
      if (e.clipboardData && e.clipboardData.items) {
        const items = e.clipboardData.items;
        for (let i = 0; i < items.length; i++) {
          if (items[i].type.indexOf('image') !== -1) {
            const blob = items[i].getAsFile();
            const reader = new FileReader();
            reader.onload = (event) => {
              setImage(event.target.result);
              setComments([]);
              setActiveArea(null);
            };
            reader.readAsDataURL(blob);
            break;
          }
        }
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    window.addEventListener('paste', handlePaste);
    return () => {
      window.removeEventListener('keydown', handleKeyDown);
      window.removeEventListener('paste', handlePaste);
    };
  }, [activeArea, comments]); // Cập nhật khi activeArea thay đổi để xóa đúng mục

  // --- UTILS ---
  const handleImageUpload = (e) => {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = (event) => {
        setImage(event.target.result);
        setComments([]);
        setActiveArea(null);
      };
      reader.readAsDataURL(file);
    }
  };

  const getMousePos = (e) => {
    if (!imageRef.current) return { x: 0, y: 0 };
    const rect = imageRef.current.getBoundingClientRect();
    return {
      x: ((e.clientX - rect.left) / rect.width) * 100,
      y: ((e.clientY - rect.top) / rect.height) * 100
    };
  };

  // --- TRANSFORM LOGIC ---
  const handleMouseDown = (e) => {
    if (!image) return;
    const pos = getMousePos(e);

    if (!transformState.type) {
      setStartPos(pos);
      setIsDrawing(true);
      setCurrentArea({ x: pos.x, y: pos.y, w: 0, h: 0, angle: 0 });
      setActiveArea(null);
    }
  };

  const startTransform = (e, area, type, handle = null) => {
    e.stopPropagation();
    const pos = getMousePos(e);
    setTransformState({ type, handle, areaId: area.id, startMouse: pos, initialData: { ...area } });
    setActiveArea(area.id);
  };

  const handleMouseMove = (e) => {
    const pos = getMousePos(e);

    if (isDrawing && startPos) {
      setCurrentArea({
        ...currentArea,
        x: Math.min(startPos.x, pos.x),
        y: Math.min(startPos.y, pos.y),
        w: Math.abs(pos.x - startPos.x),
        h: Math.abs(pos.y - startPos.y)
      });
      return;
    }

    if (transformState.type && transformState.areaId) {
      const { type, handle, areaId, startMouse, initialData } = transformState;
      const dx = pos.x - startMouse.x;
      const dy = pos.y - startMouse.y;
      
      setComments(prev => prev.map(area => {
        if (area.id !== areaId) return area;
        if (type === 'move') return { ...area, x: initialData.x + dx, y: initialData.y + dy };
        if (type === 'scale') {
          let { x, y, w, h } = initialData;
          switch (handle) {
            case 'br': w += dx; h += dy; break;
            case 'tl': x += dx; y += dy; w -= dx; h -= dy; break;
            case 'tr': y += dy; w += dx; h -= dy; break;
            case 'bl': x += dx; w -= dx; h += dy; break;
            default: break;
          }
          return { ...area, x, y, w: Math.max(1, w), h: Math.max(1, h) };
        }
        if (type === 'rotate') {
          const centerX = initialData.x + initialData.w / 2;
          const centerY = initialData.y + initialData.h / 2;
          const angle = Math.atan2(pos.y - centerY, pos.x - centerX) * (180 / Math.PI) + 90;
          return { ...area, angle };
        }
        return area;
      }));
    }
  };

  const handleMouseUp = () => {
    if (transformState.type) {
      setTransformState({ type: null, handle: null, areaId: null, startMouse: null, initialData: null });
      return;
    }

    if (isDrawing) {
      setIsDrawing(false);
      if (currentArea.w < 0.5 && currentArea.h < 0.5) {
        currentArea.w = 5; currentArea.h = 5;
      }
      if (mode === 'blur') {
        setComments([...comments, { ...currentArea, id: Date.now(), type: 'blur', text: 'Vùng bảo mật' }]);
        setCurrentArea(null);
      }
    }
  };

  const openEditModal = (area) => {
    if (area.type === 'blur') return;
    setEditingId(area.id);
    setInputText(area.text);
    setIsEditing(true);
  };

  const deleteArea = (id) => {
    setComments(prev => prev.filter(c => c.id !== id));
    if (activeArea === id) setActiveArea(null);
  };

  const saveFeedback = () => {
    if (!inputText.trim()) return;
    
    if (isEditing && editingId) {
      setComments(comments.map(c => c.id === editingId ? { ...c, text: inputText } : c));
      setIsEditing(false);
      setEditingId(null);
    } else if (currentArea) {
      setComments([...comments, { ...currentArea, id: Date.now(), text: inputText, type: 'comment', resolved: false }]);
      setCurrentArea(null);
    }
    setInputText('');
  };

  // --- LEVERAGE: COPY TEXT FEEDBACK ---
  const copyFeedbackText = () => {
    if (comments.length === 0) return;
    const textStr = comments.map((c, i) => `${i + 1}. [${c.type === 'blur' ? 'BLACKOUT' : 'NOTE'}] ${c.text || ''}`).join('\n');
    
    const textArea = document.createElement("textarea");
    textArea.value = textStr;
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      setIsCopied(true);
      setTimeout(() => setIsCopied(false), 2000);
    } catch (err) {
      console.error('Lỗi khi copy', err);
    }
    document.body.removeChild(textArea);
  };

  // --- EXPORT TO CANVAS ---
  const exportAsImage = () => {
    if (!image) return;
    setIsExporting(true);

    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    const img = new Image();
    
    img.onload = () => {
      canvas.width = img.width;
      canvas.height = img.height;
      ctx.drawImage(img, 0, 0);

      comments.forEach((area, index) => {
        const rx = (area.x / 100) * img.width;
        const ry = (area.y / 100) * img.height;
        const rw = (area.w / 100) * img.width;
        const rh = (area.h / 100) * img.height;

        ctx.save();
        ctx.translate(rx + rw / 2, ry + rh / 2);
        ctx.rotate((area.angle || 0) * Math.PI / 180);
        
        if (area.type === 'blur') {
          ctx.fillStyle = '#000000';
          ctx.fillRect(-rw / 2, -rh / 2, rw, rh);
        } else {
          ctx.strokeStyle = '#4f46e5';
          ctx.lineWidth = Math.max(4, img.width / 400); 
          ctx.strokeRect(-rw / 2, -rh / 2, rw, rh);

          ctx.font = `bold ${Math.max(14, img.width / 60)}px Arial`;
          const text = `${index + 1}. ${area.text}`;
          const m = ctx.measureText(text);
          ctx.fillStyle = '#4f46e5';
          ctx.fillRect(-rw/2, -rh/2 - 35, m.width + 12, 28);
          ctx.fillStyle = '#fff';
          ctx.textBaseline = 'middle';
          ctx.fillText(text, -rw/2 + 6, -rh/2 - 21);
        }
        ctx.restore();
      });

      const link = document.createElement('a');
      link.download = `antigravity-report-${Date.now()}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
      setIsExporting(false);
    };
    img.src = image;
  };

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 font-sans p-4 select-none">
      <input type="file" ref={fileInputRef} className="hidden" accept="image/*" onChange={handleImageUpload} />
      
      <div className="max-w-7xl mx-auto space-y-6">
        <header className="flex flex-col lg:flex-row justify-between items-center gap-6 pb-6 border-b border-slate-800">
          <div className="flex items-center gap-4">
             <div className="bg-indigo-600 p-2.5 rounded-2xl shadow-lg shadow-indigo-600/20"><ShieldAlert className="text-white" size={24} /></div>
             <h1 className="text-2xl font-black italic uppercase tracking-tighter text-white">Annotation Pro v4</h1>
          </div>
          
          <div className="flex items-center gap-3">
            <button onClick={() => fileInputRef.current.click()} className="flex items-center gap-2 bg-slate-800 px-6 py-3 rounded-2xl font-bold border border-slate-700 hover:bg-slate-700 transition-all shadow-xl">
              <Camera size={20} /> ẢNH MỚI
            </button>
            {image && (
              <button onClick={exportAsImage} disabled={isExporting} className="flex items-center gap-2 bg-emerald-600 px-8 py-3 rounded-2xl font-black shadow-lg shadow-emerald-600/20 hover:bg-emerald-500 transition-all">
                {isExporting ? "ĐANG XUẤT..." : <Download size={20} />} XUẤT FILE
              </button>
            )}
          </div>
        </header>

        {image ? (
          <div className="grid grid-cols-1 xl:grid-cols-4 gap-6">
            <div className="xl:col-span-3 space-y-4">
              <div className="bg-slate-900 border border-slate-800 rounded-3xl p-1.5 flex justify-center shadow-2xl relative">
                <div className="flex bg-slate-950 p-1.5 rounded-2xl relative gap-1 w-full max-w-md">
                  <div className={`absolute h-[calc(100%-12px)] top-1.5 rounded-xl transition-all duration-300 bg-indigo-600 shadow-lg shadow-indigo-600/40 ${mode === 'comment' ? 'left-1.5 w-[calc(50%-6px)]' : 'left-[calc(50%+3px)] w-[calc(50%-6px)]'}`} />
                  <button onClick={() => setMode('comment')} className={`relative z-10 flex-1 py-3 font-black text-xs tracking-widest uppercase transition-colors ${mode === 'comment' ? 'text-white' : 'text-slate-500 hover:text-white'}`}>GHI CHÚ (C)</button>
                  <button onClick={() => setMode('blur')} className={`relative z-10 flex-1 py-3 font-black text-xs tracking-widest uppercase transition-colors ${mode === 'blur' ? 'text-white' : 'text-slate-500 hover:text-white'}`}>CHE BẢO MẬT (B)</button>
                </div>
              </div>

              <div className="relative bg-slate-900 rounded-[2.5rem] shadow-2xl border border-slate-800 p-6 flex items-center justify-center min-h-[60vh]">
                <div 
                  className="relative cursor-crosshair max-w-full"
                  onMouseDown={handleMouseDown}
                  onMouseMove={handleMouseMove}
                  onMouseUp={handleMouseUp}
                  onMouseLeave={handleMouseUp}
                >
                  <img ref={imageRef} src={image} className="max-w-full h-auto select-none rounded-lg shadow-2xl border border-slate-800" draggable={false} />
                  
                  {comments.map((area, index) => (
                    <div
                      key={area.id}
                      style={{ 
                        left: `${area.x}%`, top: `${area.y}%`, 
                        width: `${area.w}%`, height: `${area.h}%`,
                        transform: `rotate(${area.angle || 0}deg)`
                      }}
                      className={`absolute transition-all duration-100 ${
                        area.type === 'blur' ? 'bg-black border-[2px] border-slate-600' : 'border-[3px] border-indigo-500 bg-indigo-500/5'
                      } ${activeArea === area.id ? 'z-30 ring-2 ring-white shadow-[0_0_40px_rgba(255,255,255,0.4)]' : 'z-10'} 
                        ${hoveredArea === area.id && activeArea !== area.id ? 'ring-4 ring-indigo-400/50 bg-indigo-500/20' : ''}`}
                      onMouseDown={(e) => { e.stopPropagation(); setActiveArea(area.id); }}
                    >
                      <div onMouseDown={(e) => startTransform(e, area, 'move')} className="absolute inset-4 cursor-move" />

                      {activeArea === area.id && (
                        <>
                          <div onMouseDown={(e) => startTransform(e, area, 'rotate')} className="absolute -top-12 left-1/2 -translate-x-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center cursor-alias shadow-2xl text-slate-900 border-2 border-indigo-500"><RotateCw size={18} /><div className="absolute top-10 left-1/2 -translate-x-1/2 w-0.5 h-3 bg-white" /></div>
                          
                          <div onMouseDown={(e) => startTransform(e, area, 'scale', 'tl')} className="absolute -left-2.5 -top-2.5 w-6 h-6 bg-white rounded-lg shadow-md cursor-nw-resize border-2 border-indigo-500" />
                          <div onMouseDown={(e) => startTransform(e, area, 'scale', 'tr')} className="absolute -right-2.5 -top-2.5 w-6 h-6 bg-white rounded-lg shadow-md cursor-ne-resize border-2 border-indigo-500" />
                          <div onMouseDown={(e) => startTransform(e, area, 'scale', 'bl')} className="absolute -left-2.5 -bottom-2.5 w-6 h-6 bg-white rounded-lg shadow-md cursor-sw-resize border-2 border-indigo-500" />
                          <div onMouseDown={(e) => startTransform(e, area, 'scale', 'br')} className="absolute -right-2.5 -bottom-2.5 w-6 h-6 bg-white rounded-lg shadow-md cursor-se-resize border-2 border-indigo-500" />
                        </>
                      )}

                      <div className="absolute left-0 bottom-full mb-3 whitespace-nowrap z-[40] flex items-center gap-1.5">
                        {area.type === 'comment' ? (
                          <button 
                            onClick={(e) => { e.stopPropagation(); openEditModal(area); }}
                            className="bg-indigo-600 text-white font-black text-xs px-4 py-2 rounded-xl shadow-2xl flex items-center gap-2.5 hover:bg-indigo-500 transition-all pointer-events-auto border border-white/10"
                          >
                            #{index+1} {area.text} <Pencil size={14}/>
                          </button>
                        ) : (
                          <div className="bg-slate-700 text-white font-black text-[10px] px-3 py-1.5 rounded-lg shadow-lg border border-white/5 uppercase tracking-wider">#{index+1} BLACKOUT</div>
                        )}
                        
                        <button 
                          onClick={(e) => { e.stopPropagation(); deleteArea(area.id); }}
                          className="bg-red-600 text-white p-2 rounded-xl shadow-2xl hover:bg-red-500 transition-all pointer-events-auto border border-white/10"
                          title="Xóa vùng này (hoặc bấm Delete/Backspace)"
                        >
                          <Trash2 size={16}/>
                        </button>
                      </div>
                    </div>
                  ))}

                  {currentArea && (
                    <div style={{ left: `${currentArea.x}%`, top: `${currentArea.y}%`, width: `${currentArea.w}%`, height: `${currentArea.h}%` }} className="absolute border-3 border-dashed border-white bg-white/10 z-50 pointer-events-none rounded-sm" />
                  )}
                </div>

                {((currentArea && !isDrawing && mode === 'comment') || isEditing) && (
                  <div className="absolute inset-0 bg-slate-950/90 backdrop-blur-xl flex items-center justify-center z-[100] p-6">
                    <div className="bg-slate-900 p-10 rounded-[2.5rem] w-full max-w-lg border border-slate-800 shadow-3xl animate-in fade-in zoom-in duration-300">
                      <h4 className="font-black text-2xl italic mb-8 text-white uppercase tracking-tight">{isEditing ? 'Cập nhật ghi chú' : 'Nội dung ghi chú'}</h4>
                      <textarea autoFocus value={inputText} onChange={(e) => setInputText(e.target.value)} onKeyDown={(e) => { if(e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); saveFeedback(); } if(e.key === 'Escape') { setCurrentArea(null); setIsEditing(false); setInputText(''); } }} className="w-full bg-slate-950 border border-slate-800 rounded-2xl p-6 h-40 text-white outline-none focus:ring-2 focus:ring-indigo-500 mb-8 font-medium text-lg shadow-inner" placeholder="Mô tả sửa đổi... (Nhấn Enter để lưu)" />
                      <div className="flex justify-end gap-6">
                         <button onClick={() => { setCurrentArea(null); setIsEditing(false); setEditingId(null); setInputText(''); }} className="px-8 font-bold text-slate-500 hover:text-white transition-colors text-lg">HỦY (ESC)</button>
                         <button onClick={saveFeedback} className="px-12 py-4 bg-indigo-600 rounded-2xl font-black text-white hover:bg-indigo-400 shadow-2xl shadow-indigo-600/30 text-lg transition-all active:scale-95">LƯU LẠI</button>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            </div>

            <div className="xl:col-span-1 bg-slate-900 rounded-[2.5rem] border border-slate-800 p-8 flex flex-col shadow-2xl overflow-hidden">
               <div className="flex flex-col gap-4 mb-8">
                  <div className="flex items-center justify-between">
                    <div className="space-y-1">
                      <h3 className="font-black text-xs tracking-widest uppercase text-slate-500">Layer List</h3>
                      <p className="text-[10px] text-indigo-400 font-black uppercase">{comments.length} OBJECTS</p>
                    </div>
                    <button onClick={() => setComments([])} className="text-[10px] font-black text-red-500 hover:bg-red-500/10 px-3 py-1.5 rounded-lg transition-all flex items-center gap-1.5 border border-red-500/20"><Eraser size={14}/> CLEAR</button>
                  </div>
                  
                  {/* DATA LEVERAGE: COPY TEXT BUTTON */}
                  {comments.length > 0 && (
                    <button 
                      onClick={copyFeedbackText}
                      className={`w-full py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all flex items-center justify-center gap-2 border ${isCopied ? 'bg-green-600 border-green-500 text-white' : 'bg-slate-950 border-indigo-600/30 text-indigo-400 hover:bg-indigo-600 hover:text-white'}`}
                    >
                      {isCopied ? <><CheckCircle2 size={16} /> ĐÃ COPY</> : <><Copy size={16} /> COPY TEXT</>}
                    </button>
                  )}
               </div>
               
               <div className="flex-1 overflow-y-auto space-y-4 custom-scrollbar pr-3">
                  {comments.length === 0 ? (
                    <div className="h-full flex flex-col items-center justify-center opacity-20 py-20">
                      <MessageSquare size={48} />
                      <p className="mt-4 font-black text-xs uppercase tracking-widest italic">No Data</p>
                    </div>
                  ) : (
                    comments.map((area, index) => (
                      <div 
                        key={area.id} 
                        onClick={() => setActiveArea(area.id)}
                        onMouseEnter={() => setHoveredArea(area.id)}
                        onMouseLeave={() => setHoveredArea(null)}
                        className={`p-5 rounded-3xl border cursor-pointer transition-all duration-300 ${activeArea === area.id ? 'bg-indigo-600/10 border-indigo-500 ring-1 ring-indigo-500/50' : (hoveredArea === area.id ? 'bg-slate-800 border-indigo-400/30' : 'bg-slate-950/50 border-slate-800 hover:border-slate-700')}`}
                      >
                         <div className="flex justify-between items-start mb-3">
                            <span className={`text-[10px] font-black px-2.5 py-1 rounded-lg text-white shadow-sm ${area.type === 'blur' ? 'bg-slate-700' : 'bg-indigo-600'}`}>
                              #{index+1} {area.type === 'blur' ? "BLACKOUT" : "NOTE"}
                            </span>
                            <div className="flex gap-2">
                              {area.type === 'comment' && (
                                 <button onClick={(e) => { e.stopPropagation(); openEditModal(area); }} className="text-slate-500 hover:text-indigo-400 p-2 transition-colors bg-slate-900 rounded-xl hover:shadow-lg"><Pencil size={16}/></button>
                              )}
                              <button onClick={(e) => { e.stopPropagation(); deleteArea(area.id); }} className="text-slate-500 hover:text-red-500 p-2 transition-colors bg-slate-900 rounded-xl hover:shadow-lg"><Trash2 size={16}/></button>
                            </div>
                         </div>
                         <p className={`text-sm font-semibold leading-relaxed break-words ${area.type === 'blur' ? 'text-slate-600 italic' : 'text-slate-300'}`}>{area.text}</p>
                      </div>
                    ))
                  )}
               </div>

               <button onClick={() => setImage(null)} className="mt-8 py-5 border border-slate-800 rounded-3xl text-[11px] font-black uppercase tracking-widest text-slate-500 hover:text-white hover:bg-red-900/10 hover:border-red-900/50 transition-all flex items-center justify-center gap-3"><Undo2 size={18}/> THAY ĐỔI ẢNH</button>
            </div>
          </div>
        ) : (
          <div className="h-[70vh] border-2 border-dashed border-slate-800 rounded-[4rem] bg-slate-900/20 flex flex-col items-center justify-center relative overflow-hidden shadow-inner">
             <div className="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/10 to-transparent pointer-events-none" />
             <div onClick={() => fileInputRef.current.click()} className="bg-slate-800 p-10 rounded-full mb-8 hover:scale-110 hover:bg-indigo-900/20 transition-all shadow-2xl border border-slate-700/50 cursor-pointer group z-10"><UploadCloud size={64} className="text-slate-600 group-hover:text-indigo-500 transition-colors" /></div>
             <h2 className="text-3xl font-black italic uppercase text-slate-200 tracking-tighter z-10">Start Secure Audit</h2>
             <p className="text-slate-500 text-sm mt-3 font-medium uppercase tracking-widest opacity-60 z-10 text-center leading-relaxed">
               Click / Kéo thả ảnh <br/> <span className="text-indigo-400 font-bold">hoặc ấn Ctrl + V để dán</span>
             </p>
          </div>
        )}
      </div>

      <style>{`
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 20px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #4f46e5; }
        .animate-in { animation: fadeIn 0.2s ease-out, zoomIn 0.2s ease-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes zoomIn { from { transform: scale(0.95); } to { transform: scale(1); } }
      `}</style>
    </div>
  );
};

export default App;
